{
  "name": "@react-native-motion-kit/swipe-deck",
  "version": "0.1.0",
  "description": "High-performance Tinder-style swipe deck and swipe cards for React Native, powered by Reanimated and Gesture Handler.",
  "keywords": [
    "android",
    "animation",
    "card-stack",
    "deck-swiper",
    "gesture",
    "gesture-handler",
    "ios",
    "react-native",
    "react-native-gesture-handler",
    "react-native-reanimated",
    "react-native-swipe-deck",
    "reanimated",
    "swipe-cards",
    "swipe-deck",
    "tinder-cards",
    "tinder-style"
  ],
  "homepage": "https://github.com/react-native-motion-kit/react-native-swipe-deck#readme",
  "bugs": {
    "url": "https://github.com/react-native-motion-kit/react-native-swipe-deck/issues"
  },
  "license": "MIT",
  "author": "harang <dbd02169@naver.com> (https://github.com/saseungmin)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/react-native-motion-kit/react-native-swipe-deck.git"
  },
  "workspaces": [
    "example"
  ],
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "example": "yarn workspace example",
    "example:build": "yarn example build",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:ci": "oxlint --format=github",
    "lint:fix": "oxlint --fix",
    "prepare": "bob build",
    "test": "jest",
    "typecheck": "tsc"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@jest/globals": "29.7.0",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/jest-preset": "0.85.0",
    "@react-native/metro-config": "0.85.0",
    "@testing-library/react-native": "^14.0.0",
    "@types/babel__core": "^7",
    "@types/react": "^19.2.0",
    "commitlint": "^20.5.0",
    "del-cli": "^7.0.0",
    "jest": "29.7.0",
    "lefthook": "^2.1.4",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "react": "19.2.3",
    "react-native": "0.85.0",
    "react-native-builder-bob": "^0.41.0",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-reanimated": "^4.1.0",
    "react-native-worklets": "^0.9.0",
    "test-renderer": "^1.2.0",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.75.0",
    "react-native-gesture-handler": ">=2.24.0",
    "react-native-reanimated": ">=4.0.0",
    "react-native-worklets": ">=0.5.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "jest": {
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ],
    "preset": "@react-native/jest-preset",
    "resolver": "react-native-worklets/jest/resolver",
    "setupFiles": [
      "react-native-gesture-handler/jestSetup.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest-setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|react-native-gesture-handler|react-native-reanimated|react-native-worklets)/)"
    ]
  },
  "packageManager": "yarn@4.15.0",
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "jest",
      "lefthook"
    ],
    "version": "0.62.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
